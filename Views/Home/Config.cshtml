<div x-data="config()" x-init="load()" class="space-y-6">
    <!-- Header Page -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl font-black text-slate-800 dark:text-white tracking-tight">Destinatarios de Alertas</h2>
            <p class="text-slate-500 dark:text-slate-400 font-medium mt-1">Administra los correos que recibirán notificaciones de caídas y recuperaciones.</p>
        </div>
        <button @@click="add()" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-2xl font-bold transition-all shadow-lg shadow-blue-500/20 flex items-center gap-2 group">
            <i class="fas fa-plus group-hover:rotate-90 transition-transform"></i>
            Nuevo Destinatario
        </button>
    </div>

    <!-- Recipients Grid -->
    <div class="glass-card rounded-3xl overflow-hidden border border-white/20 dark:border-slate-800/50">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-slate-200 dark:border-slate-800/60 bg-slate-50/50 dark:bg-slate-900/50">
                        <th class="px-6 py-4 text-[10px] uppercase font-black text-slate-400 tracking-widest">Nombre / Info</th>
                        <th class="px-6 py-4 text-[10px] uppercase font-black text-slate-400 tracking-widest">Correo Electrónico</th>
                        <th class="px-6 py-4 text-[10px] uppercase font-black text-slate-400 tracking-widest text-center">Estado</th>
                        <th class="px-6 py-4 text-[10px] uppercase font-black text-slate-400 tracking-widest text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800/40">
                    <template x-for="r in list" :key="r.id">
                        <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/20 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center font-bold">
                                        <span x-text="r.name ? r.name[0].toUpperCase() : '?'"></span>
                                    </div>
                                    <span class="font-bold text-slate-700 dark:text-slate-200" x-text="r.name || 'Sin Nombre'"></span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                                    <i class="fas fa-envelope text-xs opacity-50"></i>
                                    <span class="font-medium" x-text="r.email"></span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <button @@click="toggle(r)" class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none"
                                    :class="r.isActive ? 'bg-emerald-500' : 'bg-slate-300 dark:bg-slate-700'">
                                    <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform"
                                        :class="r.isActive ? 'translate-x-6' : 'translate-x-1'"></span>
                                </button>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <button @@click="edit(r)" class="w-9 h-9 rounded-xl bg-amber-50 dark:bg-amber-900/20 text-amber-500 dark:text-amber-400 hover:bg-amber-500 hover:text-white dark:hover:bg-amber-500 transition-all flex items-center justify-center">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button @@click="del(r.id)" class="w-9 h-9 rounded-xl bg-red-50 dark:bg-red-900/20 text-red-500 dark:text-red-400 hover:bg-red-500 hover:text-white dark:hover:bg-red-500 transition-all flex items-center justify-center">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>
        
        <!-- Empty State -->
        <template x-if="list.length === 0 && !loading">
            <div class="p-12 text-center">
                <div class="w-20 h-20 bg-slate-100 dark:bg-slate-800 rounded-3xl flex items-center justify-center mx-auto mb-4 text-slate-300 dark:text-slate-600">
                    <i class="fas fa-user-slash text-3xl"></i>
                </div>
                <h3 class="text-xl font-bold text-slate-700 dark:text-slate-300">No hay marcadores</h3>
                <p class="text-slate-500 dark:text-slate-500 mt-1">Agrega un correo para empezar a recibir alertas.</p>
            </div>
        </template>
    </div>

    <!-- Modal Form -->
    <template x-if="showAdd">
        <div class="fixed inset-0 z-[100] flex items-center justify-center p-4 modal-backdrop" @@click.self="showAdd = false">
            <div class="bg-white dark:bg-slate-900 w-full max-w-md rounded-3xl shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-300">
                <div class="bg-blue-600 p-6 text-white flex justify-between items-center">
                    <h3 class="text-xl font-black" x-text="isEdit ? 'Editar Marcador' : 'Nuevo Marcador'"></h3>
                    <button @@click="showAdd = false" class="opacity-70 hover:opacity-100 transition-opacity"><i class="fas fa-times"></i></button>
                </div>
                <div class="p-8 space-y-6">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 px-1">Nombre Completo</label>
                            <input type="text" x-model="form.name" placeholder="Ej: Administrador Red" class="w-full bg-slate-50 dark:bg-slate-800 border-none rounded-2xl px-5 py-3.5 focus:ring-2 focus:ring-blue-500 transition-all placeholder:text-slate-400 dark:text-white font-medium">
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 px-1">Correo Electrónico</label>
                            <input type="email" x-model="form.email" placeholder="correo@@mop.gob.sv" class="w-full bg-slate-50 dark:bg-slate-800 border-none rounded-2xl px-5 py-3.5 focus:ring-2 focus:ring-blue-500 transition-all placeholder:text-slate-400 dark:text-white font-medium">
                        </div>
                    </div>
                    <div class="flex justify-end gap-3 pt-4">
                        <button @@click="showAdd = false" class="px-6 py-3 rounded-2xl font-bold text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all">Cancelar</button>
                        <button @@click="save()" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-2xl font-bold transition-all shadow-lg shadow-blue-500/20">Guardar</button>
                    </div>
                </div>
            </div>
        </div>
    </template>
</div>

<script>
    function config() {
        return {
            list: [],
            loading: false,
            showAdd: false,
            isEdit: false,
            form: { id: 0, name: '', email: '' },

            async load() {
                this.loading = true;
                try {
                    const res = await fetch('/api/config/recipients');
                    this.list = await res.json();
                } catch (e) {
                    console.error('Error loading recipients', e);
                } finally {
                    this.loading = false;
                }
            },

            add() {
                this.isEdit = false;
                this.form = { id: 0, name: '', email: '' };
                this.showAdd = true;
            },

            edit(r) {
                this.isEdit = true;
                this.form = { ...r };
                this.showAdd = true;
            },

            async save() {
                if (!this.form.email) return Swal.fire('Error', 'El correo es obligatorio', 'error');
                
                try {
                    const isUpdate = this.isEdit;
                    const url = isUpdate ? `/api/config/recipients/${this.form.id}` : '/api/config/recipients';
                    const method = isUpdate ? 'PUT' : 'POST';

                    const res = await fetch(url, {
                        method: method,
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(this.form)
                    });
                    if (res.ok) {
                        this.showAdd = false;
                        this.isEdit = false;
                        this.form = { id: 0, name: '', email: '' };
                        this.load();
                        Swal.fire({
                            icon: 'success',
                            title: isUpdate ? 'Actualizado' : 'Guardado',
                            showConfirmButton: false,
                            timer: 1500,
                            toast: true,
                            position: 'top-end'
                        });
                    }
                } catch (e) {
                    Swal.fire('Error', 'No se pudo guardar', 'error');
                }
            },

            async toggle(r) {
                try {
                    await fetch(`/api/config/recipients/${r.id}/toggle`, { method: 'PATCH' });
                    r.isActive = !r.isActive;
                } catch (e) {
                    Swal.fire('Error', 'No se pudo cambiar el estado', 'error');
                }
            },

            async del(id) {
                const res = await Swal.fire({
                    title: '¿Estás seguro?',
                    text: 'El destinatario dejará de recibir alertas.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Sí, eliminar',
                    cancelButtonText: 'Cancelar'
                });

                if (res.isConfirmed) {
                    try {
                        await fetch(`/api/config/recipients/${id}`, { method: 'DELETE' });
                        this.load();
                        Swal.fire('Eliminado', 'Destinatario eliminado.', 'success');
                    } catch (e) {
                        Swal.fire('Error', 'No se pudo eliminar', 'error');
                    }
                }
            }
        }
    }
</script>
