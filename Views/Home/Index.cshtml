@{
    ViewData["Title"] = "Dashboard Monitor";
}

<style>
    .card-glow { position: relative; overflow: hidden; }
    .card-glow::before {
        content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
        background: conic-gradient(from 180deg, transparent 60%, rgba(99,102,241,0.08) 80%, transparent 100%);
        animation: glowSpin 8s linear infinite;
    }
    @@keyframes glowSpin { to { transform: rotate(360deg); } }

    .chart-card { transition: transform 0.2s, box-shadow 0.2s; }
    .chart-card:hover { transform: translateY(-4px); box-shadow: 0 20px 40px -12px rgba(0,0,0,0.15); }
    .dark .chart-card:hover { box-shadow: 0 20px 40px -12px rgba(0,0,0,0.4); }

    .fade-up { animation: fadeUp 0.5s ease-out both; }
    @@keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    .modal-enter { animation: modalIn 0.35s cubic-bezier(0.16,1,0.3,1) both; }
    @@keyframes modalIn { from { opacity: 0; transform: scale(0.92) translateY(16px); } to { opacity: 1; transform: scale(1) translateY(0); } }

</style>

<div x-data="dashboard()" x-init="boot()" class="space-y-6">

    <!-- ═══════ SUMMARY CARDS ═══════ -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <button @@click="type = 'all'" 
                class="glass-card rounded-2xl p-5 border flex items-center gap-4 hover:scale-[1.03] transition-all shadow-sm cursor-pointer text-left w-full group"
                :class="type === 'all' ? 'border-blue-500 ring-2 ring-blue-500/20 bg-blue-50/10' : 'border-slate-200 dark:border-slate-700/60'">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center text-white shadow-lg shadow-blue-500/30 group-hover:rotate-6 transition-transform">
                <i class="fas fa-server text-lg"></i>
            </div>
            <div><p class="text-[11px] text-slate-400 dark:text-slate-500 font-black uppercase tracking-widest">Total Marcadores</p>
            <p class="text-2xl font-extrabold dark:text-white" x-text="sum.total">0</p></div>
        </button>
        <button @@click="type = 'up'" 
                class="glass-card rounded-2xl p-5 border flex items-center gap-4 hover:scale-[1.03] transition-all shadow-sm cursor-pointer text-left w-full group"
                :class="type === 'up' ? 'border-emerald-500 ring-2 ring-emerald-500/20 bg-emerald-50/10' : 'border-slate-200 dark:border-slate-700/60'">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center text-white shadow-lg shadow-emerald-500/30 group-hover:rotate-6 transition-transform">
                <i class="fas fa-wifi text-lg"></i>
            </div>
            <div><p class="text-[11px] text-slate-400 dark:text-slate-500 font-black uppercase tracking-widest">En Línea</p>
            <p class="text-2xl font-extrabold text-emerald-500" x-text="sum.up">0</p></div>
        </button>
        <button @@click="type = 'down'" 
                class="glass-card rounded-2xl p-5 border flex items-center gap-4 hover:scale-[1.03] transition-all shadow-sm cursor-pointer text-left w-full group"
                :class="type === 'down' ? 'border-red-500 ring-2 ring-red-500/20 bg-red-50/10' : 'border-slate-200 dark:border-slate-700/60'">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-rose-400 to-red-600 flex items-center justify-center text-white shadow-lg shadow-red-500/30 group-hover:rotate-6 transition-transform">
                <i class="fas fa-plug-circle-xmark text-lg"></i>
            </div>
            <div><p class="text-[11px] text-slate-400 dark:text-slate-500 font-black uppercase tracking-widest">Fuera de Línea</p>
            <p class="text-2xl font-extrabold text-red-500" x-text="sum.down">0</p></div>
        </button>
        <div class="glass-card rounded-2xl p-5 border border-slate-200 dark:border-slate-700/60 flex items-center gap-4 hover:scale-[1.03] transition-transform shadow-sm">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-violet-400 to-purple-600 flex items-center justify-center text-white shadow-lg shadow-purple-500/30">
                <i class="fas fa-bolt text-lg"></i>
            </div>
            <div><p class="text-[11px] text-slate-400 dark:text-slate-500 font-black uppercase tracking-widest">Latencia</p>
            <p class="text-2xl font-extrabold text-purple-500" x-text="avgLat + 'ms'">0ms</p></div>
        </div>
    </div>

    <!-- ═══════ MAIN GRID ═══════ -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

        <!-- TABLE -->
        <div class="xl:col-span-2 glass-card rounded-2xl border border-gray-100 dark:border-slate-700/60 overflow-hidden">
            <div class="p-5 border-b border-slate-200 dark:border-slate-700/60 flex items-center justify-between bg-slate-50 dark:bg-slate-800">
                <h4 class="font-black text-slate-900 dark:text-white"><i class="fas fa-satellite-dish text-blue-500 mr-2"></i>Marcadores</h4>
                <div class="relative">
                    <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 dark:text-gray-600 text-xs"></i>
                    <input x-model="search" placeholder="Buscar marcador..." class="pl-9 pr-3 py-2 text-sm rounded-xl bg-slate-200/50 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 w-56 outline-none focus:ring-2 focus:ring-blue-500 dark:text-white dark:placeholder-gray-500">
                </div>
            </div>
            <div class="max-h-[480px] overflow-y-auto">
                <table class="w-full">
                    <thead class="sticky top-0 z-10 bg-slate-200 dark:bg-slate-800/90 backdrop-blur">
                        <tr class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider">
                            <th class="px-5 py-3 text-left">Nombre / Info</th>
                            <th class="px-5 py-3 text-left">IP</th>
                            <th class="px-5 py-3 text-center">Estado</th>
                            <th class="px-5 py-3 text-right">Latencia / Caída</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700/30">
                        <template x-for="d in filtered" :key="d.id">
                            <tr @@click="pick(d)" class="cursor-pointer transition-all hover:bg-slate-200/50 dark:hover:bg-blue-900/15"
                                :class="sel?.id === d.id && 'bg-blue-100/50 dark:bg-blue-900/25 ring-1 ring-blue-300 dark:ring-blue-800'">
                                <td class="px-5 py-3">
                                    <div class="flex items-center gap-2">
                                        <div>
                                            <p class="text-sm font-semibold dark:text-gray-200" x-text="d.name"></p>
                                            <p class="text-[10px] text-gray-400 dark:text-gray-600" x-text="d.despacho || '—'"></p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-5 py-3">
                                    <div class="flex flex-col">
                                        <code class="text-xs bg-gray-100 dark:bg-slate-700 px-2 py-0.5 rounded dark:text-gray-300 w-fit" x-text="d.ip"></code>
                                        <template x-if="!d.isUp && d.downSince">
                                            <span class="text-[9px] text-red-400 font-bold mt-1"><i class="fas fa-clock mr-1"></i>Visto: <span x-text="d.downSince"></span></span>
                                        </template>
                                    </div>
                                </td>
                                <td class="px-5 py-3 text-center">
                                    <span class="inline-block w-2.5 h-2.5 rounded-full status-pulse" :class="d.isUp ? 'bg-emerald-400 shadow-lg shadow-emerald-500/40' : 'bg-red-500 shadow-lg shadow-red-500/40'"></span>
                                </td>
                                <td class="px-5 py-3 text-right">
                                    <template x-if="d.isUp">
                                        <span class="text-xs font-bold tabular-nums" :class="d.latency > 150 ? 'text-red-500' : d.latency > 50 ? 'text-amber-500' : 'text-emerald-500'" x-text="d.latency + 'ms'"></span>
                                    </template>
                                    <template x-if="!d.isUp">
                                        <div class="flex flex-col items-end animate-pulse">
                                            <span class="text-[10px] bg-red-500 text-white px-2 py-0.5 rounded-md font-black mb-1">OFFLINE</span>
                                            <span class="text-xs text-red-600 dark:text-red-400 font-extrabold" x-text="'Hace ' + d.downMinutes + ' min'"></span>
                                        </div>
                                    </template>
                                </td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- SIDE PANEL -->
        <div class="space-y-6">
            <!-- Donut -->
            <div class="glass-card card-glow rounded-2xl border border-slate-200 dark:border-slate-700/60 p-6 shadow-sm">
                <h4 class="text-sm font-black text-slate-800 dark:text-white mb-3 relative z-10"><i class="fas fa-chart-pie text-violet-500 mr-2"></i>Disponibilidad</h4>
                <div class="relative h-44 z-10"><canvas id="donutCanvas"></canvas></div>
            </div>
            <!-- Quick Info -->
            <div class="glass-card rounded-2xl border border-slate-200 dark:border-slate-700/60 p-6 shadow-sm">
                <h4 class="text-sm font-black text-slate-800 dark:text-white mb-3"><i class="fas fa-info-circle text-blue-500 mr-2"></i>Detalle</h4>
                <div x-show="sel" x-cloak class="space-y-2.5 text-sm">
                    <div class="flex justify-between"><span class="text-gray-400">Nombre</span><span class="font-bold dark:text-white" x-text="sel?.name"></span></div>
                    <div class="flex justify-between"><span class="text-gray-400">IP</span><span class="font-mono text-xs dark:text-gray-300" x-text="sel?.ip"></span></div>
                    <div class="flex justify-between"><span class="text-gray-400">Despacho</span><span class="dark:text-gray-300" x-text="sel?.despacho || '—'"></span></div>
                    <div class="flex justify-between items-center border-t border-gray-100 dark:border-slate-700/60 pt-2"><span class="text-gray-400">Estado</span>
                        <div class="flex flex-col items-end">
                            <span class="text-xs font-bold px-3 py-1 rounded-full" :class="sel?.isUp ? 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-600 dark:text-emerald-400' : 'bg-red-500 text-white shadow-lg shadow-red-500/30'" x-text="sel?.isUp ? 'ONLINE' : 'CAÍDO / DOWN'"></span>
                        </div>
                    </div>
                    <template x-if="!sel?.isUp && sel?.downSince">
                        <div class="bg-red-50 dark:bg-red-900/20 p-3 rounded-xl border border-red-100 dark:border-red-900/40 mt-3">
                            <p class="text-[10px] text-red-400 uppercase font-black mb-1">Tiempo de Inactividad</p>
                            <div class="flex justify-between items-end">
                                <span class="text-lg font-black text-red-600 dark:text-red-500" x-text="sel.downMinutes + ' minutos'"></span>
                                <span class="text-[10px] text-red-400" x-text="'Desde: ' + sel.downSince"></span>
                            </div>
                        </div>
                    </template>
                    <div class="flex justify-between"><span class="text-gray-400">Latencia</span><span class="font-bold" :class="(sel?.latency||0)>150?'text-red-500':(sel?.latency||0)>50?'text-amber-500':'text-emerald-500'" x-text="(sel?.latency||0)+'ms'"></span></div>
                </div>
                <p x-show="!sel" class="text-center text-xs text-gray-300 dark:text-gray-600 py-6 italic">Selecciona un dispositivo</p>
            </div>
        </div>
    </div>

    <!-- ═══════ CHARTS SECTION ═══════ -->
    <div x-show="sel" x-cloak class="fade-up space-y-5">
        <!-- Range Selector -->
        <div class="flex items-center justify-between glass-card rounded-2xl p-4 border border-slate-200 dark:border-slate-700/60 shadow-sm">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white shadow-lg shadow-indigo-500/25">
                    <i class="fas fa-chart-area text-sm"></i>
                </div>
                <div>
                    <p class="text-[10px] text-gray-400 dark:text-gray-500 font-bold uppercase">Análisis de</p>
                    <p class="text-sm font-bold dark:text-white" x-text="sel?.name + ' — ' + sel?.ip"></p>
                </div>
                <div x-show="loading" x-cloak class="ml-4">
                    <i class="fas fa-circle-notch fa-spin text-blue-500"></i>
                </div>
            </div>
            <div class="flex bg-slate-200 dark:bg-slate-700/80 p-1 rounded-xl gap-0.5">
                <template x-for="r in ranges" :key="r.h">
                    <button @@click="setRange(r.h)" class="px-3 py-1.5 text-[11px] font-bold rounded-lg transition-all"
                        :class="rng===r.h ? 'bg-white dark:bg-slate-600 text-blue-700 dark:text-blue-300 shadow-sm' : 'text-slate-500 hover:text-slate-700 dark:hover:text-gray-300'"
                        x-text="r.label"></button>
                </template>
            </div>
        </div>

        <!-- Charts Row -->
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-5">
            <!-- LATENCY CHART -->
            <div class="chart-card glass-card rounded-2xl p-6 border border-gray-100 dark:border-slate-700/60 cursor-pointer group" @@click="openModal('latency')">
                <div class="flex items-center justify-between mb-5">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
                        <h6 class="text-sm font-bold dark:text-white">Latencia (ms)</h6>
                    </div>
                    <span class="text-[10px] text-gray-300 dark:text-gray-600 group-hover:text-blue-400 transition-colors"><i class="fas fa-expand mr-1"></i>Ampliar</span>
                </div>
                <div class="h-56 relative"><canvas id="latChart"></canvas></div>
                <div class="grid grid-cols-4 gap-2 mt-4">
                    <div class="bg-white dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl p-2 text-center shadow-sm">
                        <p class="text-[9px] text-gray-400 uppercase font-bold">Mín</p>
                        <p class="text-sm font-extrabold text-emerald-500" x-text="st.min + 'ms' || '—'"></p>
                    </div>
                    <div class="bg-white dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl p-2 text-center shadow-sm">
                        <p class="text-[9px] text-gray-400 uppercase font-bold">Máx</p>
                        <p class="text-sm font-extrabold text-red-500" x-text="st.max + 'ms' || '—'"></p>
                    </div>
                    <div class="bg-white dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl p-2 text-center shadow-sm">
                        <p class="text-[9px] text-gray-400 uppercase font-bold">Avg</p>
                        <p class="text-sm font-extrabold text-cyan-500" x-text="st.avg + 'ms' || '—'"></p>
                    </div>
                    <div class="bg-white dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl p-2 text-center shadow-sm">
                        <p class="text-[9px] text-gray-400 uppercase font-bold">Muestras</p>
                        <p class="text-sm font-extrabold text-gray-500 dark:text-gray-300" x-text="st.n || 0"></p>
                    </div>
                </div>

            </div>

            <!-- STATUS CHART -->
            <div class="chart-card glass-card rounded-2xl p-6 border border-gray-100 dark:border-slate-700/60 cursor-pointer group" @@click="openModal('status')">
                <div class="flex items-center justify-between mb-5">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
                        <h6 class="text-sm font-bold dark:text-white">Estado de Conectividad</h6>
                    </div>
                    <span class="text-[10px] text-gray-300 dark:text-gray-600 group-hover:text-blue-400 transition-colors"><i class="fas fa-expand mr-1"></i>Ampliar</span>
                </div>
                <div class="h-56 relative"><canvas id="statChart"></canvas></div>
                <div class="grid grid-cols-3 gap-2 mt-4">
                    <div class="bg-white dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl p-2 text-center shadow-sm">
                        <p class="text-[9px] text-gray-400 uppercase font-bold">Uptime</p>
                        <p class="text-sm font-extrabold text-emerald-500" x-text="st.up + '%' || '—'"></p>
                    </div>
                    <div class="bg-white dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl p-2 text-center shadow-sm">
                        <p class="text-[9px] text-gray-400 uppercase font-bold">OK</p>
                        <p class="text-sm font-extrabold text-emerald-500" x-text="st.pUp || 0"></p>
                    </div>
                    <div class="bg-white dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl p-2 text-center shadow-sm">
                        <p class="text-[9px] text-gray-400 uppercase font-bold">Caídos</p>
                        <p class="text-sm font-extrabold text-red-500" x-text="st.pDn || 0"></p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Timeline Full Width -->
        <div class="chart-card glass-card rounded-2xl p-6 border border-gray-100 dark:border-slate-700/60 cursor-pointer group" @@click="openModal('timeline')">
            <div class="flex items-center justify-between mb-5">
                <div class="flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-indigo-400"></span>
                    <h6 class="text-sm font-bold dark:text-white">Línea Temporal Completa</h6>
                </div>
                <span class="text-[10px] text-gray-300 dark:text-gray-600 group-hover:text-blue-400 transition-colors"><i class="fas fa-expand mr-1"></i>Ampliar</span>
            </div>
            <div class="h-44 relative"><canvas id="timeChart"></canvas></div>
        </div>
    </div>

    <!-- Empty State -->
    <div x-show="!sel" class="glass-card rounded-2xl border border-gray-100 dark:border-slate-700/60 p-16 text-center">
        <div class="w-20 h-20 mx-auto mb-4 rounded-2xl bg-gradient-to-br from-blue-50 to-indigo-100 dark:from-blue-900/20 dark:to-indigo-900/20 flex items-center justify-center">
            <i class="fas fa-chart-area text-3xl text-blue-300 dark:text-blue-700"></i>
        </div>
        <h4 class="font-bold text-gray-500 dark:text-gray-400 mb-1">Selecciona un Dispositivo</h4>
        <p class="text-xs text-gray-400 dark:text-gray-600">Haz clic en cualquier fila para ver gráficas detalladas</p>
    </div>

    <!-- ═══════ MODAL PREMIUM ═══════ -->
    <div x-show="mOpen" x-cloak class="fixed inset-0 z-[200] flex items-center justify-center p-6"
         @@keydown.escape.window="closeModal()">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-black/50 backdrop-blur-lg" @@click="closeModal()" x-show="mOpen"
             x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"></div>

        <!-- Modal Box -->
        <div class="relative w-full max-w-6xl bg-white dark:bg-slate-800 rounded-3xl shadow-2xl overflow-hidden border border-gray-200 dark:border-slate-700 z-10 modal-enter"
             x-show="mOpen" x-transition>
            <!-- Header -->
            <div class="relative px-8 py-5 border-b border-gray-100 dark:border-slate-700/60 bg-gradient-to-r from-gray-50 via-white to-gray-50 dark:from-slate-800 dark:via-slate-800 dark:to-slate-800">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500"></div>
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-4">
                        <div class="w-11 h-11 rounded-2xl flex items-center justify-center text-white shadow-xl"
                             :class="mType==='latency' ? 'bg-gradient-to-br from-cyan-500 to-blue-600 shadow-cyan-500/30' : mType==='status' ? 'bg-gradient-to-br from-emerald-500 to-green-600 shadow-emerald-500/30' : 'bg-gradient-to-br from-indigo-500 to-purple-600 shadow-indigo-500/30'">
                            <i :class="mType==='latency' ? 'fas fa-wave-square' : mType==='status' ? 'fas fa-heartbeat' : 'fas fa-chart-line'" class="text-lg"></i>
                        </div>
                        <div>
                            <h3 class="text-lg font-extrabold dark:text-white" x-text="mType==='latency'?'Latencia en Tiempo Real':mType==='status'?'Estado de Conectividad':'Línea Temporal Completa'"></h3>
                            <p class="text-[11px] text-gray-400 dark:text-gray-500 font-medium" x-text="sel?.name + '  •  ' + sel?.ip"></p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="hidden md:flex bg-gray-100 dark:bg-slate-700 p-1 rounded-xl gap-0.5">
                            <button @@click.stop="setRange(1)" class="px-3 py-1 text-[10px] font-bold rounded-lg transition-all" :class="rng===1 ? 'bg-white dark:bg-slate-600 text-blue-600 dark:text-blue-300 shadow-sm' : 'text-gray-400'">1H</button>
                            <button @@click.stop="setRange(6)" class="px-3 py-1 text-[10px] font-bold rounded-lg transition-all" :class="rng===6 ? 'bg-white dark:bg-slate-600 text-blue-600 dark:text-blue-300 shadow-sm' : 'text-gray-400'">6H</button>
                            <button @@click.stop="setRange(24)" class="px-3 py-1 text-[10px] font-bold rounded-lg transition-all" :class="rng===24 ? 'bg-white dark:bg-slate-600 text-blue-600 dark:text-blue-300 shadow-sm' : 'text-gray-400'">24H</button>
                            <button @@click.stop="setRange(72)" class="px-3 py-1 text-[10px] font-bold rounded-lg transition-all" :class="rng===72 ? 'bg-white dark:bg-slate-600 text-blue-600 dark:text-blue-300 shadow-sm' : 'text-gray-400'">3D</button>
                            <button @@click.stop="setRange(168)" class="px-3 py-1 text-[10px] font-bold rounded-lg transition-all" :class="rng===168 ? 'bg-white dark:bg-slate-600 text-blue-600 dark:text-blue-300 shadow-sm' : 'text-gray-400'">7D</button>
                        </div>
                        <button @@click="closeModal()" class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-slate-700 hover:bg-red-50 dark:hover:bg-red-900/20 hover:text-red-500 transition-all flex items-center justify-center">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
            </div>
            <!-- Chart Area -->
            <div class="px-8 py-6">
                <div class="relative rounded-2xl bg-gray-50/50 dark:bg-slate-900/30 p-4 border border-gray-100 dark:border-slate-700/40" style="height:52vh; min-height:320px;">
                    <canvas id="modalCanvas"></canvas>
                </div>
            </div>
            <!-- Footer Stats -->
            <div class="px-8 py-4 border-t border-gray-100 dark:border-slate-700/60 bg-gray-50/50 dark:bg-slate-900/30">
                <div class="flex items-center justify-between">
                    <div class="flex gap-6">
                        <template x-if="mType==='latency'">
                            <div class="flex gap-6">
                                <span class="flex items-center gap-1.5 text-xs"><span class="w-2 h-2 rounded-full bg-emerald-400"></span><span class="text-gray-400">Mín:</span><span class="font-extrabold text-emerald-500" x-text="st.min+'ms'"></span></span>
                                <span class="flex items-center gap-1.5 text-xs"><span class="w-2 h-2 rounded-full bg-red-400"></span><span class="text-gray-400">Máx:</span><span class="font-extrabold text-red-500" x-text="st.max+'ms'"></span></span>
                                <span class="flex items-center gap-1.5 text-xs"><span class="w-2 h-2 rounded-full bg-cyan-400"></span><span class="text-gray-400">Avg:</span><span class="font-extrabold text-cyan-500" x-text="st.avg+'ms'"></span></span>
                                <span class="flex items-center gap-1.5 text-xs"><span class="w-2 h-2 rounded-full bg-gray-400"></span><span class="text-gray-400">Muestras:</span><span class="font-extrabold dark:text-gray-300" x-text="st.n"></span></span>
                            </div>
                        </template>
                        <template x-if="mType!=='latency'">
                            <div class="flex gap-6">
                                <span class="flex items-center gap-1.5 text-xs"><span class="w-2 h-2 rounded-full bg-emerald-400"></span><span class="text-gray-400">Uptime:</span><span class="font-extrabold text-emerald-500" x-text="st.up+'%'"></span></span>
                                <span class="flex items-center gap-1.5 text-xs"><span class="text-gray-400">OK:</span><span class="font-extrabold text-emerald-500" x-text="st.pUp"></span></span>
                                <span class="flex items-center gap-1.5 text-xs"><span class="text-gray-400">Fail:</span><span class="font-extrabold text-red-500" x-text="st.pDn"></span></span>
                            </div>
                        </template>
                    </div>
                    <p class="text-[10px] text-gray-300 dark:text-gray-600 italic">Auto-actualización cada 30s</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function dashboard() {
    return {
        sum: { total:0, up:0, down:0 },
        devs: [], search: '', sel: null, avgLat: 0,
        type: 'all',
        rng: 24,
        ranges: [{h:1,label:'1H'},{h:6,label:'6H'},{h:24,label:'24H'},{h:72,label:'3D'},{h:168,label:'7D'}],
        st: { min:0, max:0, avg:0, n:0, up:0, pUp:0, pDn:0 },
        mOpen: false, mType: 'latency',
        loading: false, // Bloqueo de concurrencia
        _raw: [],
        _c: {},
        _abort: null, // Controlador de aborto para fetch
        _timers: [],  // Limpieza de timeouts activos

        boot() { 
            this.load(); 
            // El intervalo no debe interferir con la selección manual
            setInterval(() => { if(!this.loading && !this.mOpen) this.load(); }, 30000); 
        },

        async load() {
            try {
                const [s, d] = await Promise.all([
                    fetch('/api/dashboard/summary').then(r=>r.json()),
                    fetch('/api/dashboard/status-list').then(r=>r.json())
                ]);
                this.sum = s; this.devs = d;
                const up = d.filter(x=>x.isUp && x.latency>0);
                this.avgLat = up.length ? Math.round(up.reduce((a,b)=>a+b.latency,0)/up.length) : 0;
                this._donut();
                if (this.sel) { const f = d.find(x=>x.id===this.sel.id); if(f) this.sel=f; }
            } catch(e) { console.error(e); }
        },

        get filtered() {
            const q = this.search.toLowerCase();
            let base = this.devs;
            if (this.type === 'up') base = base.filter(x => x.isUp);
            if (this.type === 'down') base = base.filter(x => !x.isUp);
            return base.filter(d => d.name.toLowerCase().includes(q) || d.ip.includes(q));
        },

        pick(d) { 
            if (this.sel?.id === d.id && !this.loading) return;
            this.sel = d; 
            this.loadCharts(); 
        },

        setRange(h) { 
            this.rng = h; 
            this.loadCharts(); 
        },

                async loadCharts() {
                    if (!this.sel) return; 
                    
                    if (this._abort) this._abort.abort();
                    this._abort = new AbortController();
                    
                    this._timers.forEach(t => clearTimeout(t));
                    this._timers = [];

                    this.loading = true;
                    
                    try {
                        const res = await fetch(`/api/dashboard/chart/${this.sel.id}?hours=${this.rng}`, { 
                            signal: this._abort.signal 
                        });
                        const data = await res.json();
                        
                        this._raw = data;
                        this._stats(data);

                        // Usar requestAnimationFrame para asegurar que el DOM esté listo para el dibujo
                        const t = setTimeout(() => {
                            requestAnimationFrame(() => {
                                try {
                                    this._latency(data);
                                    this._status(data);
                                    this._timeline(data);
                                    if (this.mOpen) this._modal();
                                } catch (err) {
                                    console.error("Render Error:", err);
                                } finally {
                                    this.loading = false;
                                }
                            });
                        }, 50);
                        this._timers.push(t);

                    } catch(e) { 
                        if (e.name !== 'AbortError') {
                            console.error("Chart Fetch Error:", e);
                        }
                        this.loading = false;
                    }
                },

        _stats(d) {
            const lat = d.map(x=>x.latency).filter(v=>v>0);
            const pUp = d.filter(x=>x.value===1).length;
            const pDn = d.filter(x=>x.value===0).length;
            this.st = {
                min: lat.length ? Math.min(...lat) : 0,
                max: lat.length ? Math.max(...lat) : 0,
                avg: lat.length ? Math.round(lat.reduce((a,b)=>a+b,0)/lat.length) : 0,
                n: d.length,
                up: d.length ? Math.round(pUp/d.length*100) : 0,
                pUp, pDn
            };
        },

                // == Chart helpers ==
                _kill(id) { 
                    try {
                        const existing = Chart.getChart(id);
                        if (existing) {
                            existing.destroy();
                        }
                    } catch(e) { console.warn("Kill error on " + id, e); }
                    if (this._c[id]) delete this._c[id];
                },
                _dk() { return document.documentElement.classList.contains('dark'); },
                _gc() { const dk=this._dk(); return { grid: dk?'rgba(148,163,184,0.06)':'rgba(0,0,0,0.04)', txt: dk?'#475569':'#9ca3af', tip: dk?'#0f172a':'#fff', tipTxt: dk?'#e2e8f0':'#1e293b', tipBdr: dk?'#1e293b':'#e5e7eb' }; },

                _mkChart(id, key, cfg) {
                    const el = document.getElementById(id);
                    if (!el) return;
                    
                    // Limpieza agresiva por ID de elemento
                    this._kill(id);
                    
                    const ctx = el.getContext('2d');
                    if (!ctx) return;

                    const c = this._gc();
            const base = {
                responsive: true, maintainAspectRatio: false,
                animation: { duration: 700, easing: 'easeOutQuart' },
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { display: false },
                    tooltip: { backgroundColor: c.tip, titleColor: c.tipTxt, bodyColor: c.tipTxt, borderColor: c.tipBdr, borderWidth: 1, cornerRadius: 12, padding: 14, titleFont:{weight:'bold'}, displayColors: true, boxPadding: 4 }
                },
                scales: {
                    x: { grid: { color: c.grid, drawBorder: false }, ticks: { color: c.txt, font:{size:9}, maxRotation: 0, autoSkip: true, maxTicksLimit: 10 }, border: { display: false } },
                    y: { grid: { color: c.grid, drawBorder: false }, ticks: { color: c.txt, font:{size:9} }, border: { display: false }, ...(cfg.yOpts||{}) }
                }
            };
            // Deep merge options
            if (cfg.opts) {
                if (cfg.opts.scales) { Object.assign(base.scales.x, cfg.opts.scales.x||{}); Object.assign(base.scales.y, cfg.opts.scales.y||{}); }
                if (cfg.opts.plugins) { Object.assign(base.plugins, cfg.opts.plugins); }
            }
            this._c[key] = new Chart(el, { type: cfg.type, data: cfg.data, options: base });
        },

        // == Donut ==
        _donut() {
            const el = document.getElementById('donutCanvas');
            if (!el) return;
            this._kill('donutCanvas');
            const self = this;
            this._c['donut'] = new Chart(el, {
                type: 'doughnut',
                data: {
                    labels: ['Online','Offline'],
                    datasets: [{ data: [this.sum.up, this.sum.down], backgroundColor: ['#10b981','#ef4444'], borderWidth: 0, hoverOffset: 6 }]
                },
                options: { cutout: '72%', responsive: true, maintainAspectRatio: false, plugins: { legend:{display:false} } },
                plugins: [{
                    id: 'center',
                    afterDraw(ch) {
                        const {ctx:c, width:w, height:h} = ch;
                        c.save();
                        const pct = self.sum.total ? Math.round(self.sum.up/self.sum.total*100) : 0;
                        c.font = 'bold 28px Inter'; c.fillStyle = self._dk() ? '#f1f5f9' : '#1e293b';
                        c.textAlign='center'; c.textBaseline='middle';
                        c.fillText(pct+'%', w/2, h/2 - 8);
                        c.font = '600 9px Inter'; c.fillStyle = self._dk() ? '#64748b' : '#94a3b8';
                        c.fillText('UPTIME', w/2, h/2 + 12);
                        c.restore();
                    }
                }]
            });
        },

        // == Latency ==
        _latency(d) {
            const el = document.getElementById('latChart');
            if (!el) return;
            const ctx = el.getContext('2d');
            const g = ctx.createLinearGradient(0,0,0,220);
            g.addColorStop(0, 'rgba(6,182,212,0.25)'); g.addColorStop(1, 'rgba(6,182,212,0.0)');
            this._mkChart('latChart', 'lat', {
                type: 'line',
                data: {
                    labels: d.map(x=>x.time),
                    datasets: [
                        { label:'Latencia (ms)', data:d.map(x=>x.latency), borderColor:'#06b6d4', backgroundColor:g, fill:true, tension:0.4, borderWidth:2, pointRadius:d.length>60?0:3, pointBackgroundColor:'#06b6d4', pointHoverRadius:6, pointHoverBackgroundColor:'#fff', pointHoverBorderColor:'#06b6d4', pointHoverBorderWidth:3 },
                        { label:'Promedio', data:d.map(()=>this.st.avg), borderColor:'rgba(52,211,153,0.5)', borderWidth:1.5, borderDash:[6,4], fill:false, pointRadius:0 }
                    ]
                }
            });
        },

        // == Status ==
        _status(d) {
            this._mkChart('statChart', 'stat', {
                type: 'bar',
                data: {
                    labels: d.map(x=>x.time),
                    datasets: [{
                        label:'Estado', data:d.map(x=>x.value===1?1:-1),
                        backgroundColor: d.map(x=>x.value===1?'rgba(16,185,129,0.75)':'rgba(239,68,68,0.75)'),
                        hoverBackgroundColor: d.map(x=>x.value===1?'#10b981':'#ef4444'),
                        borderWidth:0, borderRadius:2, barPercentage:1, categoryPercentage:1
                    }]
                },
                yOpts: { min:-1.5, max:1.5, ticks:{ stepSize:1, callback:v=>v===1?'UP':v===-1?'DN':'' } },
                opts: { plugins: { tooltip: { callbacks: { label:c=>c.parsed.y>0?' ✅ Online':' ❌ Offline' } } } }
            });
        },

        // == Timeline ==
        _timeline(d) {
            const el = document.getElementById('timeChart');
            if (!el) return;
            const ctx = el.getContext('2d');
            const g = ctx.createLinearGradient(0,0,0,170);
            g.addColorStop(0, 'rgba(99,102,241,0.2)'); g.addColorStop(1, 'rgba(99,102,241,0.0)');
            const dots = d.map(x=>x.value===1?'#10b981':'#ef4444');
            this._mkChart('timeChart', 'time', {
                type: 'line',
                data: {
                    labels: d.map(x=>x.time),
                    datasets: [{
                        label:'Latencia (ms)', data:d.map(x=>x.latency),
                        borderColor:'#6366f1', backgroundColor:g, fill:true, tension:0.4, borderWidth:2,
                        pointRadius:d.length>60?0:3, pointBackgroundColor:dots, pointBorderColor:dots,
                        pointHoverRadius:6, pointHoverBackgroundColor:'#fff', pointHoverBorderWidth:3
                    }]
                },
                opts: { plugins: { tooltip: { callbacks: { afterLabel:c=>'Estado: '+(d[c.dataIndex].value===1?'✅ UP':'❌ DOWN') } } } }
            });
        },

        // == Modal ==
        openModal(type) {
            this.mType = type;
            this.mOpen = true;
            document.body.style.overflow = 'hidden';
            setTimeout(() => this._modal(), 200);
        },
        closeModal() {
            this.mOpen = false;
            document.body.style.overflow = '';
            this._kill('modal');
        },
        _modal() {
            const d = this._raw;
            if (!d || !d.length) return;
            const el = document.getElementById('modalCanvas');
            if (!el) return;
            const ctx = el.getContext('2d');

            if (this.mType === 'latency') {
                const g = ctx.createLinearGradient(0,0,0,400);
                g.addColorStop(0,'rgba(6,182,212,0.3)'); g.addColorStop(1,'rgba(6,182,212,0.0)');
                this._mkChart('modalCanvas', 'modal', {
                    type: 'line',
                    data: {
                        labels: d.map(x=>x.time),
                        datasets: [
                            { label:'Latencia (ms)', data:d.map(x=>x.latency), borderColor:'#06b6d4', backgroundColor:g, fill:true, tension:0.4, borderWidth:2.5, pointRadius:d.length>100?0:4, pointBackgroundColor:'#06b6d4', pointHoverRadius:7, pointHoverBackgroundColor:'#fff', pointHoverBorderColor:'#06b6d4', pointHoverBorderWidth:3 },
                            { label:'Promedio ('+this.st.avg+'ms)', data:d.map(()=>this.st.avg), borderColor:'rgba(52,211,153,0.6)', borderWidth:2, borderDash:[8,4], fill:false, pointRadius:0 }
                        ]
                    },
                    opts: { plugins: { legend: { display:true, position:'top', labels:{ usePointStyle:true, padding:20, font:{size:11} } } }, scales: { x: { ticks: { maxTicksLimit:20, maxRotation:45 } } } }
                });
            } else if (this.mType === 'status') {
                this._mkChart('modalCanvas', 'modal', {
                    type: 'bar',
                    data: {
                        labels: d.map(x=>x.time),
                        datasets: [{
                            label:'Estado', data:d.map(x=>x.value===1?1:-1),
                            backgroundColor: d.map(x=>x.value===1?'rgba(16,185,129,0.8)':'rgba(239,68,68,0.8)'),
                            hoverBackgroundColor: d.map(x=>x.value===1?'#10b981':'#ef4444'),
                            borderWidth:0, borderRadius:3, barPercentage:1, categoryPercentage:1
                        }]
                    },
                    yOpts: { min:-1.5, max:1.5, ticks:{ stepSize:1, font:{size:11,weight:'bold'}, callback:v=>v===1?'UP':v===-1?'DOWN':'' } },
                    opts: { plugins: { tooltip: { callbacks: { label:c=>c.parsed.y>0?' ✅ Online — Activo':' ❌ Offline — Caído' } } }, scales: { x: { ticks: { maxTicksLimit:20, maxRotation:45 } } } }
                });
            } else {
                const g = ctx.createLinearGradient(0,0,0,400);
                g.addColorStop(0,'rgba(99,102,241,0.25)'); g.addColorStop(1,'rgba(99,102,241,0.0)');
                const dots = d.map(x=>x.value===1?'#10b981':'#ef4444');
                this._mkChart('modalCanvas', 'modal', {
                    type: 'line',
                    data: {
                        labels: d.map(x=>x.time),
                        datasets: [{
                            label:'Latencia (ms)', data:d.map(x=>x.latency),
                            borderColor:'#6366f1', backgroundColor:g, fill:true, tension:0.4, borderWidth:2.5,
                            pointRadius:d.length>100?0:4, pointBackgroundColor:dots, pointBorderColor:dots,
                            pointHoverRadius:7, pointHoverBackgroundColor:'#fff', pointHoverBorderWidth:3
                        }]
                    },
                    opts: { plugins: { legend:{display:true,position:'top',labels:{usePointStyle:true,padding:20}}, tooltip:{ callbacks:{ afterLabel:c=>'Estado: '+(d[c.dataIndex].value===1?'✅ UP':'❌ DOWN') } } }, scales:{ x:{ticks:{maxTicksLimit:20,maxRotation:45}} } }
                });
            }
        }
    }
}
</script>
}
