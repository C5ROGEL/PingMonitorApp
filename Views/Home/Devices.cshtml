@{
    ViewData["Title"] = "Gestión de IPs";
}

<div x-data="deviceManagerApp()" x-init="init()" class="space-y-6">
    <!-- Header Actions -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-gray-800 dark:text-white">Marcadores</h2>
            <p class="text-gray-500 dark:text-gray-400 text-sm">Administra los equipos y IPs para el monitoreo ICMP</p>
        </div>
        <button @@click="openAddModal()" 
                class="bg-gradient-to-r from-blue-600 to-blue-700 text-white px-6 py-2.5 rounded-xl font-semibold shadow-md shadow-blue-500/25 hover:shadow-lg hover:shadow-blue-500/30 transition-all flex items-center gap-2 hover:scale-[1.02]">
            <i class="fas fa-plus"></i>
            <span>Nuevo Marcador</span>
        </button>
    </div>

    <!-- Devices Table -->
    <div class="glass-card rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
        <div class="p-6 border-b border-gray-100 dark:border-slate-700">
             <div class="relative w-full max-w-md">
                <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
                <input type="text" x-model="search" placeholder="Filtrar marcadores..." 
                       class="pl-10 pr-4 py-2 bg-gray-50 dark:bg-slate-700 border border-gray-200 dark:border-slate-600 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-full dark:text-gray-200 dark:placeholder-gray-500">
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-gray-50 dark:bg-slate-700/50 text-gray-400 dark:text-gray-500 text-xs uppercase font-semibold">
                    <tr>
                        <th class="px-6 py-4">ID</th>
                        <th class="px-6 py-4">Nombre</th>
                        <th class="px-6 py-4">Dirección IP</th>
                        <th class="px-6 py-4">Despacho</th>
                        <th class="px-6 py-4">Activo</th>
                        <th class="px-6 py-4 text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-slate-700/50">
                    <template x-for="device in filteredDevices" :key="device.id">
                        <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/30 transition-colors">
                            <td class="px-6 py-4 text-sm font-mono text-gray-400 dark:text-gray-500" x-text="device.id"></td>
                            <td class="px-6 py-4 font-semibold text-gray-700 dark:text-gray-200" x-text="device.name"></td>
                            <td class="px-6 py-4">
                                <span class="bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 px-3 py-1 rounded-full text-xs font-mono font-bold" x-text="device.ip"></span>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400" x-text="device.despacho"></td>
                            <td class="px-6 py-4">
                                <span :class="device.isActive ? 'bg-green-100 dark:bg-emerald-900/40 text-green-700 dark:text-emerald-400' : 'bg-gray-100 dark:bg-slate-600 text-gray-500 dark:text-gray-400'" 
                                      class="px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wider" 
                                      x-text="device.isActive ? 'SÍ' : 'NO'"></span>
                            </td>
                            <td class="px-6 py-4 text-right space-x-2">
                                <button @@click="openEditModal(device)" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 p-2 transition-colors">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button @@click="deleteDevice(device.id)" class="text-red-500 dark:text-red-400 hover:text-red-700 dark:hover:text-red-300 p-2 transition-colors">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deviceManagerApp() {
            return {
                devices: [],
                search: '',

                init() {
                    this.loadDevices();
                },

                async loadDevices() {
                    const res = await fetch('/api/devices');
                    this.devices = await res.json();
                },

                get filteredDevices() {
                    return this.devices.filter(d => 
                        d.name.toLowerCase().includes(this.search.toLowerCase()) || 
                        d.ip.includes(this.search)
                    );
                },

                async openAddModal() {
                    const { value: formValues } = await Swal.fire({
                        title: 'Nuevo Marcador',
                        html:
                            '<input id="swal-name" class="swal2-input" placeholder="Nombre (Ej: Router Central)">' +
                            '<input id="swal-ip" class="swal2-input" placeholder="IP (Ej: 192.168.1.1)">' +
                            '<input id="swal-despacho" class="swal2-input" placeholder="Despacho/Ubicación">',
                        focusConfirm: false,
                        showCancelButton: true,
                        confirmButtonText: 'Guardar',
                        cancelButtonText: 'Cancelar',
                        preConfirm: () => {
                            return {
                                name: document.getElementById('swal-name').value,
                                ip: document.getElementById('swal-ip').value,
                                despacho: document.getElementById('swal-despacho').value,
                                isActive: true
                            }
                        }
                    });

                    if (formValues) {
                        if (!formValues.name || !formValues.ip) {
                            Swal.fire('Error', 'Nombre e IP son obligatorios', 'error');
                            return;
                        }

                        const res = await fetch('/api/devices', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(formValues)
                        });

                        if (res.ok) {
                            Swal.fire('Éxito', 'Marcador agregado correctamente', 'success');
                            this.loadDevices();
                        }
                    }
                },

                async openEditModal(device) {
                    const { value: formValues } = await Swal.fire({
                        title: 'Editar Marcador',
                        html:
                            `<input id="swal-name" class="swal2-input" value="${device.name}" placeholder="Nombre">` +
                            `<input id="swal-ip" class="swal2-input" value="${device.ip}" placeholder="IP">` +
                            `<input id="swal-despacho" class="swal2-input" value="${device.despacho || ''}" placeholder="Despacho">` +
                            `<div class="mt-4"><label><input type="checkbox" id="swal-active" ${device.isActive ? 'checked' : ''}> Activo para monitoreo</label></div>`,
                        focusConfirm: false,
                        showCancelButton: true,
                        confirmButtonText: 'Actualizar',
                        preConfirm: () => {
                            return {
                                id: device.id,
                                name: document.getElementById('swal-name').value,
                                ip: document.getElementById('swal-ip').value,
                                despacho: document.getElementById('swal-despacho').value,
                                isActive: document.getElementById('swal-active').checked
                            }
                        }
                    });

                    if (formValues) {
                        const res = await fetch(`/api/devices/${device.id}`, {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(formValues)
                        });

                        if (res.ok) {
                            Swal.fire('Actualizado', 'Los cambios se guardaron', 'success');
                            this.loadDevices();
                        }
                    }
                },

                async deleteDevice(id) {
                    const result = await Swal.fire({
                        title: '¿Estás seguro?',
                        text: "Esta acción no se puede deshacer",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        confirmButtonText: 'Sí, eliminar',
                        cancelButtonText: 'Cancelar'
                    });

                    if (result.isConfirmed) {
                        const res = await fetch(`/api/devices/${id}`, { method: 'DELETE' });
                        if (res.ok) {
                            Swal.fire('Eliminado', 'El marcador fue removido', 'success');
                            this.loadDevices();
                        }
                    }
                }
            }
        }
    </script>
}
